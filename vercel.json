{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm install --frozen-lockfile && pnpm build",
  "outputDirectory": "out",
  "framework": null,
  "trailingSlash": true,
  "headers": [
    {
      "source": "/_next/static/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/admin/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/review/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/knowledge",
      "destination": "/docs/",
      "permanent": true
    },
    {
      "source": "/knowledge/:path*",
      "destination": "/docs/",
      "permanent": true
    },
    {
      "source": "/diagnostics/:path*",
      "destination": "/ontology/insights/",
      "permanent": true
    },
    {
      "source": "/settings/ontology/:path*",
      "destination": "/settings/",
      "permanent": true
    }
  ]
}
