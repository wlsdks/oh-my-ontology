# Firebase Web SDK 설정
# Firebase Console → 프로젝트 설정 → 일반 → 내 앱 → SDK 설정 및 구성에서 복사.
#
# 사용법: 이 파일을 .env.local 로 복사한 뒤 실제 값으로 채운다.
#   cp .env.example .env.local

NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
# 선택. 기본 정적 export 빌드는 시드/데모 데이터를 사용하므로 next build
# 시점에 Firestore 를 호출하지 않는다. 'firestore' 로 두면 빌드 시점에
# Firestore 에서 직접 읽는다.
# OMOT_BUILD_PROJECT_SOURCE=firestore
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# 외부 IAM 연동 (선택). 설정하면 이메일·비밀번호 로그인/회원가입이
# JWT 세션 기반 IAM 을 우선 사용한다.
NEXT_PUBLIC_IAM_BASE_URL=

# 공개 데모 로그인 계정 (정적 사이트 특성상 공개 가능한 읽기 전용 계정만 권장)
NEXT_PUBLIC_DEMO_LOGIN_EMAIL=
NEXT_PUBLIC_DEMO_LOGIN_PASSWORD=

# 로컬 개발에서만 권한 가드 우회 버튼 노출. 1 로 두면 localhost / 127.0.0.1 에서만 작동.
NEXT_PUBLIC_DEV_ADMIN_BYPASS=

# 로컬 emulator 연결
NEXT_PUBLIC_FIREBASE_USE_EMULATORS=
NEXT_PUBLIC_FIRESTORE_EMULATOR_HOST=
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=
