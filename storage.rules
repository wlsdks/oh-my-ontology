rules_version = '2';

// oh-my-ontology — Firebase Storage Rules (single-user mode)
//
// screenshots/: 공개 읽기, 인증 사용자 업로드
// knowledge-documents/: 인증 사용자 원문 저장 (append-only)

service firebase.storage {
  match /b/{bucket}/o {

    function isAuthed() {
      return request.auth != null;
    }

    match /screenshots/{projectSlug}/{file} {
      allow read: if true;
      allow write: if isAuthed()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(png|jpeg|webp)');
    }

    match /knowledge-documents/{documentId}/{file} {
      allow read: if isAuthed();
      allow write: if resource == null
        && isAuthed()
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('(text/markdown|text/plain|application/octet-stream)');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
